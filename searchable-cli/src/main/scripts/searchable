#!/usr/bin/env bash
# Launcher for the Searchable CLI.
#
# Usage:
#   searchable --config /path/to/searchable.yaml <subcommand> [args]
#
# Resolution order (the first match wins):
#   1. $SEARCHABLE_HOME/searchable-cli.jar (installed distribution)
#   2. ${self_dir}/searchable-cli.jar (jar placed next to this script)
#   3. searchable-cli/target/searchable-cli-*.jar (developer checkout
#      after `mvn -B -f searchable-cli/pom.xml package`)
#
# The CLI ships as a single self-contained fat jar (built with
# maven-shade-plugin; see docs/adr/0001-cli-executable-jar-with-shade-plugin.md),
# so no sibling lib/ directory is needed.
set -euo pipefail

self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_jar() {
  if [[ -n "${SEARCHABLE_HOME:-}" && -f "${SEARCHABLE_HOME}/searchable-cli.jar" ]]; then
    printf '%s' "${SEARCHABLE_HOME}/searchable-cli.jar"
    return
  fi
  if [[ -f "${self_dir}/searchable-cli.jar" ]]; then
    printf '%s' "${self_dir}/searchable-cli.jar"
    return
  fi
  # Dev checkout: scripts live at searchable-cli/src/main/scripts/, target/
  # is three levels up.
  local target_dir="${self_dir}/../../../target"
  if [[ -d "${target_dir}" ]]; then
    local jar
    for jar in "${target_dir}"/searchable-cli-*.jar; do
      local base="${jar##*/}"
      # Skip the non-shaded "original-" artifact that shade keeps as backup.
      if [[ "${base}" != original-* && -f "${jar}" ]]; then
        printf '%s' "${jar}"
        return
      fi
    done
  fi
  echo "searchable: cannot locate searchable-cli executable jar." >&2
  echo "  - Set SEARCHABLE_HOME to a directory containing searchable-cli.jar," >&2
  echo "  - place the jar next to this script, or" >&2
  echo "  - run 'mvn -B -f searchable-cli/pom.xml package' first." >&2
  exit 2
}

jar="$(resolve_jar)"
exec "${JAVA:-java}" ${SEARCHABLE_OPTS:-} -jar "${jar}" "$@"
